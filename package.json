{
  "name": "age-and-semantics-information",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Comprehensive resource for research on Age of Information, Semantics, Goal-Oriented Communications, AoII, VoI",
  "author": "Zhongdong Liu",
  "keywords": [
    "age-of-information",
    "AoI",
    "freshness",
    "networking",
    "research",
    "academic"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "node scripts/composeData.js && vite",
    "build": "node scripts/composeData.js && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md}\" \"*.{js,json,md}\""
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-gfm": "^4.0.1",
    "d3-force": "^3.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.0",
    "js-yaml": "^4.1.0",
